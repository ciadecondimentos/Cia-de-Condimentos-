{
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://cia-de-condimentos.onrender.com/api/$1" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/(.*)", "destination": "/admin.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/login/(.*)", "destination": "/login.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
