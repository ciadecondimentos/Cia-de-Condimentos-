{
  "buildCommand": "echo 'Static deployment'",
  "outputDirectory": "frontend",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/", "destination": "/admin.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/login/", "destination": "/login.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
